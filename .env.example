# Copy this file to `.env` and fill in your real keys.
# Each key is only required if you use that provider — leave the others as-is if you don't.

# Smartlead — required for sending campaigns and (optionally) Smart Prospects lead search.
# Get from: https://app.smartlead.ai → Settings → API & Webhooks.
SMARTLEAD_API_KEY=your-key-here

# Prospeo — required if you use Prospeo as a lead provider in find-leads.
# Get from: https://app.prospeo.io → Settings → API.
PROSPEO_API_KEY=your-key-here
